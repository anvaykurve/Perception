import rclpy
from rclpy.node import Node
from sensor_msgs.msg import PointCloud
from visualization_msgs.msg import Marker, MarkerArray
import numpy as np
from sklearn.cluster import DBSCAN

class CarmakerCloudFilter(Node):
    def __init__(self):
        super().__init__('carmaker_cloud_filter')
        
        self.subscription = self.create_subscription(
            PointCloud,
            '/carmaker/pointcloud', 
            self.cloud_callback,
            10
        )
        
        # Publisher for the filtered points
        self.cloud_publisher = self.create_publisher(PointCloud, '/filtered_pointcloud', 10)
        
        # NEW: Publisher for the clustered cone bounding boxes/markers
        self.marker_publisher = self.create_publisher(MarkerArray, '/detected_cones', 10)
        
        self.get_logger().info("Filter and Clustering node started.")

    def cloud_callback(self, msg):
        filtered_msg = PointCloud()
        filtered_msg.header = msg.header 
        
        ground_z_threshold = -0.4 
        valid_points = []
        
        # 1. GROUND REMOVAL
        for p in msg.points:
            if p.z > ground_z_threshold:
                filtered_msg.points.append(p)
                # Store points in a simple list for the clustering math
                valid_points.append([p.x, p.y, p.z])

        self.cloud_publisher.publish(filtered_msg)
        
        # 2. CLUSTERING (DBSCAN)
        if len(valid_points) > 0:
            points_np = np.array(valid_points)
            
            # eps: Max distance (in meters) between points in the same cone.
            # min_samples: Minimum points to qualify as a cone. Set to 20 to target ~50 point groups.
            dbscan = DBSCAN(eps=0.4, min_samples=20)
            labels = dbscan.fit_predict(points_np)
            
            # 3. PUBLISH DETECTIONS AS MARKERS
            marker_array = MarkerArray()
            unique_labels = set(labels)
            
            marker_id = 0
            for label in unique_labels:
                if label == -1:
                    continue  # DBSCAN labels noise as -1, we ignore it
                
                # Extract all points belonging to this specific cone
                cluster_points = points_np[labels == label]
                
                # Find the center (centroid) of the cone
                centroid = np.mean(cluster_points, axis=0)
                
                # Create a 3D Cylinder marker to represent the detected cone
                marker = Marker()
                marker.header = msg.header
                marker.ns = "detected_cones"
                marker.id = marker_id
                marker.type = Marker.CYLINDER
                marker.action = Marker.ADD
                
                marker.pose.position.x = float(centroid[0])
                marker.pose.position.y = float(centroid[1])
                marker.pose.position.z = float(centroid[2])
                
                # Set standard racing cone dimensions (~30cm wide, 50cm tall)
                marker.scale.x = 0.3
                marker.scale.y = 0.3
                marker.scale.z = 0.5
                
                # Set color to bright Orange
                marker.color.a = 1.0 # 1.0 is fully opaque
                marker.color.r = 1.0 
                marker.color.g = 0.5 
                marker.color.b = 0.0
                
                marker_array.markers.append(marker)
                marker_id += 1
                
            self.marker_publisher.publish(marker_array)

def main(args=None):
    rclpy.init(args=args)
    node = CarmakerCloudFilter()
    
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
